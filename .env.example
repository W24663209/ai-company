ce# AI Company Environment Configuration

# Claude CLI binary path (defaults to 'claude' in PATH)
CLAUDE_BIN=claude

# Optional: explicit JAVA_HOME for specific JDK versions
# JAVA_HOME_11=/Library/Java/JavaVirtualMachines/jdk-11.jdk/Contents/Home
# JAVA_HOME_17=/Library/Java/JavaVirtualMachines/jdk-17.jdk/Contents/Home

# Optional: NVM directory for Node version switching
# NVM_DIR=/Users/YOUR_NAME/.nvm
